{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "//": "Per-machine overrides. Copy to settings.local.json (git-ignored) and add",
  "//2": "permissions you trust ONLY on this box. Keeps the shared settings.json clean.",
  "//3": "Never put deny-list weakening or secret-hook changes here.",

  "permissions": {
    "allow": [
      "Bash(railway *)",
      "Bash(docker compose *)"
    ]
  }
}
